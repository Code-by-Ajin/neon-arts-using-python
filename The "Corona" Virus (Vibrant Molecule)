import turtle

t = turtle.Turtle()
s = turtle.Screen()
s.bgcolor("black")
t.pencolor("lime") # Neon Green
t.speed(0)

b = 0
while b < 200:
    t.forward(b)
    t.left(b)
    b += 1
    # Adding a secondary "glow" line
    if b % 2 == 0:
        t.pencolor("white")
    else:
        t.pencolor("#39FF14")

turtle.done()
